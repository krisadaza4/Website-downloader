# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directory
# https://docs.npmjs.com/misc/faq#should-i-check-my-node-modules-folder-into-git
node_modules

# Generated website archives (recreated at runtime) — keep the folder, not its contents
public/sites/*
!public/sites/.gitkeep

# Downloaded site mirrors land at the project root as <hostname>/ folders and
# are not part of the app — don't commit wget output.

# Design reference (not part of the app)
rebate-cash.jpg

# Local screenshots (the README uses a GitHub-hosted image)
*-screenshot.png

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
